# ─────────────────────────────────────────────
#  MT5 Telegram Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── HTTP Server ──────────────────────────────
PORT=8080
HOST=0.0.0.0

# ── PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://mt5user:CHANGE_ME@localhost:5432/mt5db

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Encryption ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MT5_SECRET_KEY=

# ── MT5 Paths ────────────────────────────────
# Full portable MT5 base installation (must exist before starting this service)
MT5_BASE_DIR=C:/mt5_base
# Root where per-user instance folders are created
MT5_INSTANCES_DIR=C:/mt5_instances
MT5_TERMINAL_EXE=terminal64.exe

# ── MT5 Queue Limits ────────────────────────
# Max simultaneous MT5 terminal launches
MT5_MAX_CONCURRENT=5
# Milliseconds to wait for auth confirmation inside the MT5 log
MT5_LOGIN_TIMEOUT_MS=60000

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs